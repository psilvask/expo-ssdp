{
  "name": "expo-ssdp",
  "version": "0.0.4",
  "description": "Cross-platform Expo native module for SSDP/UPnP device discovery on local networks. Supports iOS and Android with full New Architecture / Turbo Module compatibility.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "android/src",
    "android/build.gradle",
    "ios",
    "expo-module.config.json",
    "expo-ssdp.podspec"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest"
  },
  "keywords": [
    "expo-module",
    "expo",
    "ssdp",
    "upnp",
    "discovery",
    "network",
    "dlna",
    "chromecast",
    "smart-tv",
    "iot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bc-bane/expo-ssdp"
  },
  "author": "bc-bane",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bc-bane/expo-ssdp/issues"
  },
  "homepage": "https://github.com/bc-bane/expo-ssdp#readme",
  "expo": {
    "autoInstall": true,
    "name": "ExpoSsdp"
  },
  "peerDependencies": {
    "expo": ">=56.0.0",
    "react": ">=19.2.0",
    "react-native": ">=0.78.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "expo": "^56.0.0",
    "expo-modules-core": "~56.0.0",
    "jest": "^30.4.2",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0"
  }
}
